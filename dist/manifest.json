{
  "manifest_version": 3,
  "name": "LassoSS",
  "version": "1.0",
  "description": "Freeform screenshot extension",
  "permissions": [
    "activeTab",
    "tabs",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "service-worker-loader.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "js": [
        "assets/content.ts-ChDBCFs1.js"
      ],
      "matches": [
        "<all_urls>"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "LassoSS"
  },
  "web_accessible_resources": [
    {
      "matches": [
        "<all_urls>"
      ],
      "resources": [
        "assets/content.ts-ChDBCFs1.js"
      ],
      "use_dynamic_url": false
    }
  ]
}

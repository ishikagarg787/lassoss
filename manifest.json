{
  "manifest_version": 3,

  "name": "LassoSS",

  "version": "1.0",

  "description": "Freeform screenshot extension",

  "permissions": [
    "activeTab",
    "tabs",
    "scripting"
  ],

  "host_permissions": [
    "<all_urls>"
  ],

  "background": {
    "service_worker": "src/background.ts",
    "type": "module"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content.ts"],
      "run_at": "document_idle"
    }
  ],

  "action": {
    "default_title": "LassoSS"
  }
}